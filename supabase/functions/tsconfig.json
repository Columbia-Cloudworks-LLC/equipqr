
{
  "compilerOptions": {
    "target": "ES2022",
    "moduleResolution": "node",
    "baseUrl": "./",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["./**/*.ts"],
  "exclude": ["node_modules"]
}
